# Copy this to .env.local for local development
# In production, set these in the Vercel dashboard under Settings > Environment Variables

# Your Anthropic API key — get one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: lock the API to your deployed domain only (e.g. my-job-hunter.vercel.app)
ALLOWED_ORIGIN=your-app.vercel.app
